# ─────────────────────────────────────────────
#  CekID Bot — Konfigurasi Environment
#  Salin file ini jadi .env lalu isi nilainya
# ─────────────────────────────────────────────

# Token bot dari @BotFather
BOT_TOKEN=

# API credentials dari https://my.telegram.org
TELETHON_API_ID=
TELETHON_API_HASH=

# String session Telethon (jalankan gen_session.py untuk generate)
TELETHON_SESSION=
