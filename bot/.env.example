# ─────────────────────────────────────────────────────────────
#  CekID Bot — Konfigurasi Environment
#  Salin file ini menjadi .env lalu isi nilainya
#
#  Di Pterodactyl: isi nilai di Startup Variables panel,
#  ATAU copy file ini jadi .env di folder bot.
# ─────────────────────────────────────────────────────────────

# Token bot dari @BotFather
BOT_TOKEN=

# API credentials dari https://my.telegram.org
TELETHON_API_ID=
TELETHON_API_HASH=

# Session Telethon — KOSONGKAN dulu, akan diisi otomatis saat
# bot pertama kali dijalankan (melalui setup interaktif di console).
TELETHON_SESSION=
